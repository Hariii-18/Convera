# Supabase Postgres connection string.
# Project settings -> Database -> Connection string -> URI (use the "Session pooler"
# host/port for local dev, or the direct connection on port 5432 for migrations).
# Password must be URL-encoded if it contains special characters.
DATABASE_URL=postgresql+psycopg2://postgres.<project-ref>:<db-password>@aws-0-<region>.pooler.supabase.com:5432/postgres

# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
# This is unrelated to Supabase Auth: the app issues and verifies its own JWTs.
SECRET_KEY=change-me-to-a-random-64-byte-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Comma-separated list of origins allowed to call this API
CORS_ORIGINS=http://localhost:3000

ENVIRONMENT=development

# Supabase project URL, e.g. https://<project-ref>.supabase.co
SUPABASE_URL=https://<project-ref>.supabase.co

# Service role key (Project settings -> API -> service_role secret).
# Server-side only — never expose this to the frontend. Used solely to call
# Supabase Storage; Supabase Auth is not used and does not touch this key.
SUPABASE_SERVICE_ROLE_KEY=change-me-service-role-key

# Name of the Supabase Storage bucket used for file uploads
SUPABASE_STORAGE_BUCKET=converra-files

# Transcription provider (see app/services/transcription/factory.py).
# Currently only "faster_whisper" is implemented.
TRANSCRIPTION_PROVIDER=faster_whisper

# faster-whisper model settings. Model size trades accuracy for speed/RAM:
# tiny < base < small < medium < large-v3. "int8" compute type runs well on CPU.
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
