# PostgreSQL connection string
DATABASE_URL=postgresql+psycopg2://converra:converra@localhost:5432/converra

# JWT signing secret — generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-random-64-byte-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Comma-separated list of origins allowed to call this API
CORS_ORIGINS=http://localhost:3000

ENVIRONMENT=development
